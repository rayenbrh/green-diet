# Copier vers .env et remplir les valeurs. Ne jamais committer .env.

NODE_ENV=production
PORT=5001

# MongoDB (local ou Atlas) — remplacer par votre chaîne réelle
MONGODB_URI=mongodb://localhost:27017/greendiet

JWT_SECRET=remplacer_par_au_moins_32_caracteres_aleatoires
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=autre_secret_refresh_au_moins_32_caracteres
JWT_REFRESH_EXPIRES_IN=30d

ADMIN_SECRET_KEY=cle_pour_enregistrer_le_premier_admin

# CORS : origines exactes du navigateur (schéma + hôte ; le port 443/80 est omis dans l’en-tête Origin).
# FRONTEND_URL = origine de la boutique (ex. https://boutique.votredomaine.tn)
FRONTEND_URL=https://boutique.votredomaine.tn
# ADMIN_URL = origine du navigateur quand on ouvre l’admin. Si l’admin est sous /admin/ sur le MÊME host que la boutique, mettre la même valeur que FRONTEND_URL :
ADMIN_URL=https://boutique.votredomaine.tn
# (Si l’admin est servie uniquement sur l’API : https://api.votredomaine.tn)
# Optionnel : origines supplémentaires séparées par des virgules (www, préprod, URL Easy Panel temporaire, etc.)
# CORS_ORIGINS=https://www.boutique.votredomaine.tn,https://boutique-preview.easypanel.host

# Derrière un reverse proxy (Easy Panel, Traefik, etc.) — recommandé en production
TRUST_PROXY=1

# URL publique HTTPS de l’API sans /api — URLs d’images absolues (ex. https://api.green-diet.tn)
# PUBLIC_API_URL=https://api.green-diet.tn

# Si la boutique et l’API ne sont pas « same-site » (ex. hôtes *.railway.app différents) : HTTPS obligatoire
# COOKIE_SAMESITE=none

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_PHONE=+21600000000
STORE_NAME=Green Diet Sfax
