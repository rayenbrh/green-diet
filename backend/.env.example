# Copier vers .env et remplir les valeurs. Ne jamais committer .env.

NODE_ENV=production
PORT=5001

# MongoDB (local ou Atlas) — remplacer par votre chaîne réelle
MONGODB_URI=mongodb://localhost:27017/greendiet

JWT_SECRET=remplacer_par_au_moins_32_caracteres_aleatoires
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=autre_secret_refresh_au_moins_32_caracteres
JWT_REFRESH_EXPIRES_IN=30d

ADMIN_SECRET_KEY=cle_pour_enregistrer_le_premier_admin

# CORS : origines exactes du navigateur (schéma + hôte ; pas de slash final).
# Raccourci si boutique + admin sur le même domaine (ex. green-diet.tn/admin/) :
SITE_URL=https://green-diet.tn
# Ou explicitement :
# FRONTEND_URL=https://green-diet.tn
# ADMIN_URL=https://green-diet.tn
# Optionnel : www, préprod, ancienne URL Easy Panel
# CORS_ORIGINS=https://www.green-diet.tn

# URL publique HTTPS de l’API sans /api (obligatoire si API sur un autre domaine que la boutique)
PUBLIC_API_URL=https://dokanzemni-backend-green-diet.2bj94x.easypanel.host

# Cross-site (boutique ≠ API) : COOKIE_SAMESITE=none est appliqué automatiquement si PUBLIC_API_URL ≠ SITE_URL
# COOKIE_SAMESITE=none

# Derrière un reverse proxy (Easy Panel, Traefik, etc.) — recommandé en production
TRUST_PROXY=1

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_PHONE=+21600000000
STORE_NAME=Green Diet Sfax
