# Fichier pour le build / dev de la boutique (Vite). Les variables VITE_* sont figées au moment du build.

# Production (API + admin sur le même host) :
# VITE_API_URL=https://api.votredomaine.tn/api
# VITE_BACKEND_ORIGIN=https://api.votredomaine.tn
# VITE_ADMIN_URL=https://api.votredomaine.tn/admin/

# Développement local (API sur le port 5001) :
VITE_API_URL=http://localhost:5001/api
VITE_BACKEND_ORIGIN=http://localhost:5001
VITE_ADMIN_URL=http://localhost:5001/admin/
